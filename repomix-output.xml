          margin: 1.5rem 0;
        }

        [contenteditable] a {
          color: #d4af37;
          text-decoration: underline;
          font-weight: 500;
          transition: color 0.2s;
        }

        [contenteditable] a:hover {
          color: #b8933d;
        }

        [contenteditable] img {
          max-width: 100%;
          height: auto;
          border-radius: 0.5rem;
          margin: 1.5rem 0;
          box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        }

        [contenteditable] strong,
        [contenteditable] b {
          font-weight: 700;
          color: #111827;
        }

        [contenteditable] em,
        [contenteditable] i {
          font-style: italic;
        }

        [contenteditable] u {
          text-decoration: underline;
        }
      `}</style>
    </div>
  );
}
