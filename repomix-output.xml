                                      {schedule.split(':')[0]}:
                                    </span>
                                    <span className="text-gray-600">
                                      {schedule.split(':').slice(1).join(':')}
                                    </span>
                                  </div>
                                ))}
                              </div>
                            )}
                          </div>
                        )}
