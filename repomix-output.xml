    <DialogDescription className="sr-only">
      Gestionnaire de fichiers multimédias
    </DialogDescription>
          </DialogHeader>
          <MediaLibrary
            bucket="product-images"
            onSelect={(url) => handleAddImage(url)}
            onClose={() => setOpen(false)}
          />
        </DialogContent>
      </Dialog>
    </div>
  );
}
