    SELECT 1 FROM information_schema.columns
    WHERE table_name = 'live_streams' AND column_name = 'winner_user_id'
  ) THEN
    ALTER TABLE live_streams ADD COLUMN winner_user_id uuid REFERENCES profiles(id);
