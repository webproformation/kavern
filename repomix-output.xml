          className="bg-gradient-to-r from-[#b8933d] to-[#d4af37] hover:from-[#9a7a2f] hover:to-[#b8933d] text-white"
        >
          <Save className="h-5 w-5 mr-2" />
          {saving ? "Enregistrement..." : "Enregistrer le produit"}
        </Button>
      </div>
    </div>
  );
}
