<body>
    <div class="container">
        <h1>🔧 Nettoyage Cache Admin</h1>
        <p class="subtitle">
            Projet: <strong>qcqbtmvbvipsxwjlgjvk</strong>
            <span class="badge">VERROUILLÉ</span>
        </p>

        <div class="warning">
            <strong>⚠️ Attention :</strong> Cette opération va vous déconnecter et effacer toutes les données en cache. Vous devrez vous reconnecter ensuite.
        </div>

        <div class="step">
            <h3>Étape 1 : Nettoyage Complet</h3>
            <p>Cliquez sur le bouton ci-dessous pour vider le cache et forcer la déconnexion.</p>
            <button onclick="clearCache()">🗑️ Vider le Cache et Déconnecter</button>
        </div>

        <div class="step">
            <h3>Étape 2 : Reconnexion Admin</h3>
            <p>Après le rechargement, connectez-vous avec :</p>
            <div class="code">
                Email: contact@webproformation.fr<br>
                Mot de passe: [votre mot de passe]
            </div>
        </div>

        <div class="step">
            <h3>Étape 3 : Vérification</h3>
            <p>Après reconnexion, vérifiez que le bandeau apparaît :</p>
            <div class="code">
                🛡️ SESSION ADMINISTRATEUR : WEBPRO<br>
                (contact@webproformation.fr)
            </div>
        </div>

        <div class="success" id="success">
            ✅ Cache vidé avec succès !<br>
            Rechargement dans 2 secondes...
        </div>
    </div>

    <script>
        async function clearCache() {
            try {
                // Vider localStorage
                localStorage.clear();
                console.log('✅ localStorage vidé');

                // Vider sessionStorage
                sessionStorage.clear();
                console.log('✅ sessionStorage vidé');

                // Vider les cookies Supabase
                document.cookie.split(";").forEach(function(c) {
                    document.cookie = c.replace(/^ +/, "").replace(/=.*/, "=;expires=" + new Date().toUTCString() + ";path=/");
                });
                console.log('✅ Cookies vidés');

                // Déconnexion Supabase si disponible
                if (window.supabase && window.supabase.auth) {
                    await window.supabase.auth.signOut();
                    console.log('✅ Déconnexion Supabase effectuée');
                }

                // Afficher le message de succès
                document.getElementById('success').style.display = 'block';

