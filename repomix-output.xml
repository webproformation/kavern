      setBalance(0);
    } else {
      setBalance(parseFloat(data?.wallet_balance || '0'));
    }

    setLoading(false);
  };

  useEffect(() => {
    refreshBalance();
  }, [user]);

  return { balance, loading, refreshBalance };
}
