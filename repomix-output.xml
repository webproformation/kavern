                    Parties restantes : <span className="text-[#D4AF37] font-bold text-xl">{remainingPlays}</span> <span className="text-gray-500">/</span> {maxPlays}
                  </p>
                </div>
              </div>
            </>
          )}

        </CardContent>
      </Card>
    </div>
  );
}
