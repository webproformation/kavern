interface LiveStream {
  id: string;
  title: string;
  status: string;
}

export function LiveBanner() {
  const [currentLive, setCurrentLive] = useState<LiveStream | null>(null);

  useEffect(() => {
    checkLiveStatus();

    const channel = supabase
      .channel('live_status')
      .on(
        'postgres_changes',
        {
          event: '*',
          schema: 'public',
          table: 'live_streams',
        },
        () => {
          checkLiveStatus();
        }
      )
      .subscribe();

    return () => {
      supabase.removeChannel(channel);
    };
