  ) THEN
    ALTER TABLE products ADD COLUMN is_variable_product boolean DEFAULT false;
  END IF;
END $$;

-- Créer la table des variations
CREATE TABLE IF NOT EXISTS product_variations (
  id uuid PRIMARY KEY DEFAULT gen_random_uuid(),
