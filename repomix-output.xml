        quantity: quantity
      };

      const { data: orderItem, error: itemError } = await supabase
        .from('order_items')
        .insert(itemData)
        .select()
        .single();

      if (itemError) {
        throw new Error(`Erreur création item: ${itemError.message}`);
      }

      console.log('✅ Item créé:', orderItem.product_name);

      const testResult = {
        success: true,
