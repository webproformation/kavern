const updates = [
  {
    code: 'mondial_relay',
    cost: 5.90,
    is_relay: true,
  },
  {
    code: 'gls_relay',
    cost: 5.90,
    is_relay: true,
  },
  {
    code: 'gls_home',
    cost: 7.90,
    is_relay: false,
  },
  {
    code: 'colissimo_home',
    cost: 8.90,
    is_relay: false,
  },
  {
